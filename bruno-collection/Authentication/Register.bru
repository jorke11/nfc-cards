meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "test@example.com",
    "password": "SecurePassword123!"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("userId", res.body.user.id);
    bru.setVar("accessToken", res.body.accessToken);
  }
}
